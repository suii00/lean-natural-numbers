/-
## C. Stone‚ÄďńĆech compactification ‚ÄĒ universal property skeleton

We encode ő≤X together with the canonical map `őĻ : ContinuousMap X ő≤X` and the universal
property for maps into compact Hausdorff spaces. This mirrors the md design,
yet leaves heavy analysis to future dedicated development.
-/

section StoneCechSkeleton

variable (X : Type*) [TopologicalSpace X]

structure StoneCechCompactification (X : Type*) [TopologicalSpace X] where
  ő≤X : Type*
  instTopő≤X : TopologicalSpace ő≤X
  instCompő≤X : CompactSpace ő≤X
  instT2ő≤X : T2Space ő≤X
  őĻ : ContinuousMap X ő≤X
  dense_range : DenseRange őĻ
  universal :
    ‚ąÄ (K : Type*) (_ : TopologicalSpace K) (_ : CompactSpace K) (_ : T2Space K),
      ‚ąÄ f : ContinuousMap X K, ‚ąÉ! F : ContinuousMap ő≤X K, F.comp őĻ = f

-- Provide typeclass instances for the carrier `ő≤X` stored inside a compactification.
instance instTopologicalSpace_beta (S : StoneCechCompactification X) :
    TopologicalSpace S.ő≤X := S.instTopő≤X

instance instCompactSpace_beta (S : StoneCechCompactification X) :
    CompactSpace S.ő≤X := S.instCompő≤X

instance instT2Space_beta (S : StoneCechCompactification X) :
    T2Space S.ő≤X := S.instT2ő≤X

/-
Convenience API: abstract lifting and its `simp`-friendly consequences from the
universal property. This works for any `StoneCechCompactification X` instance,
including the trivial one below or a mathlib-backed one.
-/

noncomputable def StoneCechCompactification.lift
    {X : Type*} [TopologicalSpace X]
    (S : StoneCechCompactification X)
    (K : Type*) [TopologicalSpace K] [CompactSpace K] [T2Space K]
    (f : ContinuousMap X K) : ContinuousMap S.ő≤X K :=
  Classical.choose (S.universal K (inferInstance) (inferInstance) (inferInstance) f)

@[simp] lemma StoneCechCompactification.lift_comp
    {X : Type*} [TopologicalSpace X]
    (S : StoneCechCompactification X)
    (K : Type*) [TopologicalSpace K] [CompactSpace K] [T2Space K]
    (f : ContinuousMap X K) :
    (S.lift K f).comp S.őĻ = f := by
  classical
  simpa [StoneCechCompactification.lift]
    using (Classical.choose_spec (S.universal K (inferInstance) (inferInstance) (inferInstance) f)).1

@[simp] lemma StoneCechCompactification.lift_comp_apply
    {X : Type*} [TopologicalSpace X]
    (S : StoneCechCompactification X)
    (K : Type*) [TopologicalSpace K] [CompactSpace K] [T2Space K]
    (f : ContinuousMap X K) (x : X) :
    ((S.lift K f).comp S.őĻ) x = f x := by
  classical
  have := S.lift_comp (K:=K) f
  exact congrArg (fun (h : ContinuousMap X K) => h x) this

lemma StoneCechCompactification.lift_unique
    {X : Type*} [TopologicalSpace X]
    (S : StoneCechCompactification X)
    (K : Type*) [TopologicalSpace K] [CompactSpace K] [T2Space K]
    (f : ContinuousMap X K) {G : ContinuousMap S.ő≤X K}
    (hG : G.comp S.őĻ = f) :
    G = S.lift K f := by
  classical
  have huniq :=
    (Classical.choose_spec (S.universal K (inferInstance) (inferInstance) (inferInstance) f)).2
  -- huniq : ‚ąÄ y, (y.comp S.őĻ = f) ‚Üí y = Classical.choose (...)
  have : G = Classical.choose (S.universal K (inferInstance) (inferInstance) (inferInstance) f) :=
    huniq G hG
  simpa [StoneCechCompactification.lift] using this

/-
Trivial compactification: when `X` is already compact Hausdorff, we can take
ő≤X = X and őĻ = id. This satisfies the universal property with `F = f`.
This gives a working instance without importing mathlib‚Äôs `StoneCech`.
-/

noncomputable def StoneCechCompactification.trivial
    (X : Type*) [TopologicalSpace X]
    [CompactSpace X] [T2Space X] : StoneCechCompactification X :=
{ ő≤X := X
, instTopő≤X := inferInstance
, instCompő≤X := inferInstance
, instT2ő≤X := inferInstance
, őĻ := ContinuousMap.id X
, dense_range := by
    -- range(id) = univ is dense
    classical
    simpa using (denseRange_id : DenseRange (fun x : X => x))
, universal := by
    intro K _ _ _ f
    refine ‚ü®f, ?comp, ?uniq‚ü©
    ¬∑ -- F ‚ąė őĻ = f with F = f and őĻ = id
      ext x; rfl
    ¬∑ -- uniqueness: if G ‚ąė id = f then G = f
      intro G hG
      ext x
      -- evaluate both sides; `hG` gives function extensionality pointwise
      -- since `őĻ = id`, we have `G x = (G.comp (ContinuousMap.id X)) x`
      have := congrArg (fun (h : ContinuousMap X K) => h x) hG
      simpa using this
}

end StoneCechSkeleton

/-
## C'. Stone‚ÄďńĆech from mathlib (integration)

This realizes the abstract `StoneCechCompactification` by mathlib‚Äôs `StoneCech`:
ő≤X := `StoneCech X`, őĻ := the canonical unit embedding, and the universal arrow
provided by `StoneCech.extend`. The uniqueness is discharged by density of őĻ
and T‚āā on the codomain.
-/

section StoneCechFromMathlib

variable (X : Type*) [TopologicalSpace X]

noncomputable def StoneCechCompactification.fromMathlib :
    StoneCechCompactification X :=
{ ő≤X := StoneCech X
, instTopő≤X := inferInstance
, instCompő≤X := inferInstance
, instT2ő≤X := inferInstance
, őĻ := ‚ü®stoneCechUnit, continuous_stoneCechUnit‚ü©
, dense_range := by
    simpa using (denseRange_stoneCechUnit : DenseRange (stoneCechUnit : X ‚Üí StoneCech X))
, universal := by
    intro K _ _ _ f
    classical
    -- Existence: use the canonical continuous extension from mathlib
    let F : ContinuousMap (StoneCech X) K :=
      ‚ü®stoneCechExtend (őĪ := X) (ő≤ := K) (g := fun x => f x) f.continuous,
        continuous_stoneCechExtend (őĪ := X) (ő≤ := K) (g := fun x => f x) f.continuous‚ü©
    refine ‚ü®F, ?comp, ?uniq‚ü©
    ¬∑ -- ő≤-rule: extension comp unit = original
      -- Prove pointwise using `simp` with the extension lemma.
      ext x
      -- Goal: F (stoneCechUnit x) = f x
      -- `simp [F]` unfolds `F` to `stoneCechExtend ‚Ä¶`, and then
      -- `stoneCechExtend_extends` reduces it to `f x`.
      simp [F]
    ¬∑ -- Uniqueness via `stoneCech_hom_ext`
      intro G hG
      have h‚āĀ : Continuous (G : StoneCech X ‚Üí K) := G.continuous
      have h‚āā : Continuous (F : StoneCech X ‚Üí K) := F.continuous
      -- both sides agree after precomposition with the unit map
      -- Start with equality of bundled maps after composing with `őĻ`:
      have hFcomp : F.comp ‚ü®stoneCechUnit, continuous_stoneCechUnit‚ü© = f := by
        -- Same pointwise argument, now for `F`.
        ext x; simp [F]
      have hEq : G.comp ‚ü®stoneCechUnit, continuous_stoneCechUnit‚ü©
                = F.comp ‚ü®stoneCechUnit, continuous_stoneCechUnit‚ü© := by
        simpa [hFcomp] using hG
      -- Now get pointwise equality on the dense image of `stoneCechUnit`:
      have hcomp : (G ‚ąė stoneCechUnit) = (F ‚ąė stoneCechUnit) := by
        ext x; simpa [Function.comp] using
          congrArg (fun (h : ContinuousMap X K) => h x) hEq
      -- Uniqueness of continuous extensions from dense subsets in T‚āā spaces:
      -- `stoneCech_hom_ext` yields equality as functions, so we ext to upgrade to `ContinuousMap`.
      have hfun : (fun y => G y) = (fun y => F y) :=
        stoneCech_hom_ext (őĪ := X) (ő≤ := K) h‚āĀ h‚āā hcomp
      ext y; simpa using congrArg (fun h => h y) hfun
}

