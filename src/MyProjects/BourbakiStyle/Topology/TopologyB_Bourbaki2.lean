/-
## A. Product universality via projections

We formalize the spirit ‚Äúproduct = structure generated by projections‚ÄĚ:
- continuity of projections `ŌÄ‚āĀ, ŌÄ‚āā`;
- continuity criterion for a map into a product via its components;
- existence and uniqueness of the mediating map `‚ü®f, g‚ü©`.
-/

section ProductUniversality

variable {T X Y : Type*}
variable [TopologicalSpace T] [TopologicalSpace X] [TopologicalSpace Y]

-- Projections (morphisms) from the ordered pair structure X √ó Y.
def ŌÄ‚āĀ : X √ó Y ‚Üí X := fun p => p.1
def ŌÄ‚āā : X √ó Y ‚Üí Y := fun p => p.2

lemma continuous_ŌÄ‚āĀ : Continuous (ŌÄ‚āĀ : X √ó Y ‚Üí X) := by
  simpa [ŌÄ‚āĀ] using continuous_fst

lemma continuous_ŌÄ‚āā : Continuous (ŌÄ‚āā : X √ó Y ‚Üí Y) := by
  simpa [ŌÄ‚āā] using continuous_snd

/-
Continuity into a product is equivalent to continuity of the two components
obtained by composing with the projections. This is the universal property
in Bourbaki‚Äôs language: the product topology is the coarsest making ŌÄ‚āĀ, ŌÄ‚āā
continuous, and continuity is tested componentwise.
-/
theorem continuous_iff_proj (h : T ‚Üí X √ó Y) :
    Continuous h ‚ÜĒ
      Continuous (fun t => (h t).1) ‚ąß Continuous (fun t => (h t).2) := by
  constructor
  ¬∑ intro hh
    exact ‚ü®continuous_fst.comp hh, continuous_snd.comp hh‚ü©
  ¬∑ rintro ‚ü®h‚āĀ, h‚āā‚ü©
    -- Use `Continuous.prodMk` on the components to build continuity of `h`.
    -- We rewrite `h` as `fun t => ((h t).1, (h t).2)` to `simpa`.
    have : Continuous (fun t => ((h t).1, (h t).2)) := h‚āĀ.prodMk h‚āā
    simpa using this

/-
Existence and uniqueness of the mediating map into a product.
Given continuous `f : T ‚Üí X` and `g : T ‚Üí Y`, there is a unique continuous
`h : T ‚Üí X √ó Y` such that `ŌÄ‚āĀ ‚ąė h = f` and `ŌÄ‚āā ‚ąė h = g`.
-/
theorem exists_unique_lift_to_prod {f : T ‚Üí X} {g : T ‚Üí Y}
    (hf : Continuous f) (hg : Continuous g) :
    ‚ąÉ! h : T ‚Üí X √ó Y,
      Continuous h ‚ąß (‚ąÄ t, (h t).1 = f t) ‚ąß (‚ąÄ t, (h t).2 = g t) := by
  refine ‚ü®(fun t => (f t, g t)), ?exist, ?uniq‚ü©
  ¬∑ -- existence: the canonical pairing is continuous and has the desired components
    refine And.intro ?hcont (And.intro ?hfst ?hsnd)
    ¬∑ simpa using hf.prodMk hg
    ¬∑ intro t; rfl
    ¬∑ intro t; rfl
  ¬∑ -- uniqueness: any other h with the same components must be pointwise equal
    intro h hh
    rcases hh with ‚ü®_hc, hfst, hsnd‚ü©
    apply funext
    intro t
    -- Compare components, then use `Prod.ext`.
    apply Prod.ext
    ¬∑ simpa using hfst t
    ¬∑ simpa using hsnd t

/-
As a quick corollary, pairing with projections recovers the map.
This is the ő≤-rule for the universal property.
-/
lemma fst_pair_eq (f : T ‚Üí X) (g : T ‚Üí Y) (t : T) : ((f t, g t).1) = f t := rfl
lemma snd_pair_eq (f : T ‚Üí X) (g : T ‚Üí Y) (t : T) : ((f t, g t).2) = g t := rfl

end ProductUniversality

/-
## A. (Category level) Diagonal ‚ä£ Product in `TopCat`

We implement the diagonal functor őĒ : TopCat ‚•§ TopCat √ó TopCat and the
product functor √ó : TopCat √ó TopCat ‚•§ TopCat, and exhibit the adjunction
Hom(őĒX, (Y, Z)) ‚ČÉ Hom(X, Y √ó Z). The hom-sets reduce to pairs of continuous
maps versus a single continuous map into the product, matching the Bourbaki
ordered-pair perspective.
-/

/-
section TopCatAdjunction

open CategoryTheory

/- őĒ: duplicate objects and morphisms. -/
def deltaTop : TopCat ‚•§ TopCat √ó TopCat where
  obj X := ‚ü®X, X‚ü©
  map {X Y} (f : X ‚ü∂ Y) := ‚ü®f, f‚ü©
  map_id X := by
    -- identities are componentwise
    ext <;> rfl
  map_comp {X Y Z} (f : X ‚ü∂ Y) (g : Y ‚ü∂ Z) := by
    -- composition is componentwise
    ext <;> rfl

/- √ó: binary product on objects as cartesian product of spaces; on morphisms
it acts via `ContinuousMap.prodMap`.
-/
def prodTop : TopCat √ó TopCat ‚•§ TopCat where
  obj X := TopCat.of (X.1 √ó X.2)
  map {X Y} (f : X ‚ü∂ Y) :=
    (‚ü®(fun p : X.1 √ó X.2 => (f.1 p.1, f.2 p.2)), by
      -- continuity by components
      have h1 : Continuous fun p : X.1 √ó X.2 => f.1 p.1 := by
        simpa using ((ContinuousMap.continuous (f.1)).comp continuous_fst)
      have h2 : Continuous fun p : X.1 √ó X.2 => f.2 p.2 := by
        simpa using ((ContinuousMap.continuous (f.2)).comp continuous_snd)
      exact h1.prodMk h2‚ü© : ContinuousMap (X.1 √ó X.2) (Y.1 √ó Y.2))
  map_id X := by
    -- identity acts componentwise
    ext p <;> rfl
  map_comp {X Y Z} (f : X ‚ü∂ Y) (g : Y ‚ü∂ Z) := by
    -- composition is componentwise
    ext p <;> rfl

/- The hom-set equivalence for the adjunction. -/
noncomputable def homEquivDeltaProd
    (X : TopCat) (YZ : TopCat √ó TopCat) :
    ((deltaTop.obj X) ‚ü∂ YZ) ‚ČÉ (X ‚ü∂ prodTop.obj YZ) :=
{ toFun :=
    fun fg =>
      (‚ü®(fun x => (fg.1 x, fg.2 x)), by
        simpa using ((ContinuousMap.continuous (fg.1)).prodMk (ContinuousMap.continuous (fg.2)))‚ü© :
        ContinuousMap X (YZ.1 √ó YZ.2))
, invFun :=
    fun h =>
      ((‚ü®(fun x => (h x).1), by
          simpa using (continuous_fst.comp (ContinuousMap.continuous h))‚ü© : ContinuousMap X YZ.1),
       (‚ü®(fun x => (h x).2), by
          simpa using (continuous_snd.comp (ContinuousMap.continuous h))‚ü© : ContinuousMap X YZ.2))
, left_inv := by
    intro fg; ext x <;> rfl
, right_inv := by
    intro h; ext p <;> rfl }

/- The adjunction őĒ ‚ä£ √ó specialized to `TopCat`. -/
-- (Optional) One can package `homEquivDeltaProd` into an adjunction using
-- `Adjunction.mkOfHomEquiv`. We keep the hom-set equivalence explicit here.

end TopCatAdjunction
-/

/-
## A'. Exponential direction (skeleton)

We record currying/uncurrying at the level of plain functions (ordered pairs ‚Üí
functions into function spaces) and reserve continuity/topological refinements
for future development (e.g. under `[LocallyCompactSpace]` hypotheses). This
keeps the Bourbaki pairing perspective explicit and light.
-/

section ExponentialSkeleton

variable {X Y Z : Type*}

/-- Currying: functions on a product are functions returning functions. -/
def curry (f : X √ó Y ‚Üí Z) : X ‚Üí Y ‚Üí Z :=
  fun x y => f (x, y)

/-- Uncurrying: functions returning functions are functions on a product. -/
def uncurry (g : X ‚Üí Y ‚Üí Z) : X √ó Y ‚Üí Z :=
  fun p => g p.1 p.2

@[simp] lemma curry_uncurry (g : X ‚Üí Y ‚Üí Z) : curry (uncurry g) = g := rfl
@[simp] lemma uncurry_curry (f : X √ó Y ‚Üí Z) : uncurry (curry f) = f := by
  funext p; cases p; rfl

end ExponentialSkeleton

section ExponentialLaw

open ContinuousMap

variable {X Y Z : Type*}
variable [TopologicalSpace X] [TopologicalSpace Y] [TopologicalSpace Z]

/-- Exponential law: `ContinuousMap (X √ó Y) Z ‚ČÉ‚āú ContinuousMap X (ContinuousMap Y Z)` under local compactness. -/
noncomputable def exponential_homeo
    [LocallyCompactSpace X] [LocallyCompactSpace Y] :
    ContinuousMap (X √ó Y) Z ‚ČÉ‚āú ContinuousMap X (ContinuousMap Y Z) :=
  Homeomorph.curry (X:=X) (Y:=Y) (Z:=Z)

@[simp] lemma exponential_homeo_apply
    [LocallyCompactSpace X] [LocallyCompactSpace Y]
    (F : ContinuousMap (X √ó Y) Z) (x : X) (y : Y) :
    (exponential_homeo (X:=X) (Y:=Y) (Z:=Z) F x) y = F (x, y) := rfl

@[simp] lemma exponential_homeo_symm_apply
    [LocallyCompactSpace X] [LocallyCompactSpace Y]
    (G : ContinuousMap X (ContinuousMap Y Z)) (p : X √ó Y) :
    (exponential_homeo (X:=X) (Y:=Y) (Z:=Z)).symm G p = G p.1 p.2 := rfl

/-- Continuity of the evaluation map `(f, y) ‚Ü¶ f y` under the compact-open topology. -/
theorem continuous_eval
    [LocallyCompactPair Y Z] :
    Continuous (fun p : ContinuousMap Y Z √ó Y => p.1 p.2) := by
  simpa using (ContinuousEval.continuous_eval :
    Continuous (fun p : ContinuousMap Y Z √ó Y => p.1 p.2))

end ExponentialLaw

/-
## B. Covering spaces ‚ÄĒ Bourbaki-style skeleton

We package the essence of an evenly covered neighborhood in terms of a local
homeomorphism to a product `U √ó I` with discrete fiber `I`. This keeps the
ordered-pair-and-projection viewpoint explicit. The definition below is a
faithful skeleton: it captures the shape and the key data while staying light.
-/

section CoveringSpaces

open scoped Topology

variable {E B : Type*}
variable [TopologicalSpace E] [TopologicalSpace B]

/- Small helpers to stabilize endpoints and `simp` across mathlib versions. -/

@[inline] def I0 : unitInterval := ‚ü®0, by simp‚ü©
@[inline] def I1 : unitInterval := ‚ü®1, by simp‚ü©

@[simp] lemma coe_I0 : ((I0 : unitInterval) : ‚ĄĚ) = 0 := rfl
@[simp] lemma coe_I1 : ((I1 : unitInterval) : ‚ĄĚ) = 1 := rfl

/- Normalized API for `Path.map`: pass a function and its continuity. -/
@[simp] lemma path_map_apply
  {X Y : Type*} [TopologicalSpace X] [TopologicalSpace Y]
  {x y : X} (ő≥ : Path x y) (f : X ‚Üí Y) (hf : Continuous f) (t : ‚ÜĎunitInterval) :
  (ő≥.map (f := f) hf) t = f (ő≥ t) := rfl

@[simp] lemma path_source_I0
  {X : Type*} [TopologicalSpace X] {x y : X} (ő≥ : Path x y) :
  ő≥ I0 = x := by simpa [I0] using (ő≥.source)

@[simp] lemma path_target_I1
  {X : Type*} [TopologicalSpace X] {x y : X} (ő≥ : Path x y) :
  ő≥ I1 = y := by simpa [I1] using (ő≥.target)

/-
`CoveringMap p` asserts that around every base point `b : B`, the preimage of a
small neighborhood `U` decomposes as a product `U √ó I` for a discrete index
set `I`. We keep the commuting condition with the projection implicit in this
first skeleton, focusing on the core decomposition datum.
-/
  structure CoveringMap (p : E ‚Üí B) : Prop where
    continuous : Continuous p
    evenlyCovered :
      ‚ąÄ b : B,
        ‚ąÉ (U : Set B), IsOpen U ‚ąß b ‚ąą U ‚ąß
          ‚ąÉ (I : Type*) (_ : TopologicalSpace I) (_ : DiscreteTopology I),
          ‚ąÉ e : (Subtype fun e : E => p e ‚ąą U) ‚ČÉ‚āú ((Subtype fun x : B => x ‚ąą U) √ó I),
            (‚ąÄ s, ((e s).1 : Subtype fun x : B => x ‚ąą U).1 = p s.1)

  /-
  Evenly-covered data at a base point `b`. This packages the witness of
  `CoveringMap.evenlyCovered b` into a reusable record with convenient
  projections and helpers. We store the topology and discreteness on the fiber
  index `I` as fields (to be re-instantiated locally when needed).
  -/
  structure EvenlyCoveredAt (p : E ‚Üí B) (b : B) where
    U : Set B
    isOpenU : IsOpen U
    memU : b ‚ąą U
    I : Type*
    instTopI : TopologicalSpace I
    instDiscI : @DiscreteTopology I instTopI
    e : (Subtype fun e : E => p e ‚ąą U)
        ‚ČÉ‚āú ((Subtype fun x : B => x ‚ąą U) √ó I)
    base : ‚ąÄ s,
      ((e s).1 : Subtype fun x : B => x ‚ąą U).1 = p s.1

  /-
  Provide the stored topology/discrete topology on `d.I` as instances so that
  typeclass search always picks exactly the topology bundled in `d`.
  This avoids instance mismatch errors like "synthesized instance not
  definitionally equal" when working with products `({x // x ‚ąą d.U} √ó d.I)`.
  -/
  -- Note: we intentionally do NOT provide global instances for `d.I` here.
  -- Per the guideline, we will introduce `haveI : TopologicalSpace d.I := d.instTopI`
  -- (and similarly for `DiscreteTopology`) only within proofs that need them.


  namespace EvenlyCoveredAt

  variable {p : E ‚Üí B} {b : B}

  /-
  NOTE (temporary): We defer `sheet`/`sheet_base` to avoid instance definality
  issues. We will rely on the bundled `sheetMap` defined via `d.e.symm` and
  prove ő≤ at the bundled level.
  -/
  -- noncomputable def sheet (d : EvenlyCoveredAt p b)
  --     (i : d.I) : (Subtype fun x : B => x ‚ąą d.U)
  --       ‚Üí (Subtype fun e : E => p e ‚ąą d.U) :=
  -- by
  --   classical
  --   exact fun u => d.e.toEquiv.symm (u, i)

  -- lemma sheet_base (d : EvenlyCoveredAt p b) (i : d.I)
  --     (u : Subtype fun x : B => x ‚ąą d.U) :
  --     p ((d.sheet i u).1) = u.1 := by
  --   classical
  --   set s := d.e.toEquiv.symm (u, i)
  --   have hs : d.e.toEquiv s = (u, i) := by
  --     subst s; simpa using (d.e.toEquiv.left_inv (u, i))
  --   have hb' : ((d.e.toEquiv s).1 : Subtype fun x : B => x ‚ąą d.U).1 = p s.1 := by
  --     simpa using (d.base s)
  --   have hfst : ((d.e.toEquiv s).1) = u := congrArg Prod.fst hs
  --   have hfst_val : ((d.e.toEquiv s).1).1 = u.1 := by
  --     simpa using congrArg Subtype.val hfst
  --   have : u.1 = p s.1 := by
  --     simpa [hfst_val] using hb'
  --   change p ((d.e.toEquiv.symm (u, i)).1) = u.1
  --   simpa [s] using this.symm

  -- (Optional) If needed later: continuity of the unbundled sheet map can be
  -- recovered from `sheetMap` and `inclE`. We omit it here to avoid instance
  -- definality issues during early phases.

  /-- The inclusion `U ‚Ü™ B` as a bundled continuous map. -/
  noncomputable def inclB (d : EvenlyCoveredAt p b) :
      ContinuousMap (Subtype fun x : B => x ‚ąą d.U) B :=
    ‚ü®(fun u => u.1), continuous_subtype_val‚ü©

  /-- The inclusion `{e // p e ‚ąą U} ‚Ü™ E` as a bundled continuous map. -/
  noncomputable def inclE (d : EvenlyCoveredAt p b) :
      ContinuousMap (Subtype fun e : E => p e ‚ąą d.U) E :=
    ‚ü®(fun s => s.1), continuous_subtype_val‚ü©

  -- The `i`-th sheet as a bundled continuous map (haveI scoped in the proof).
  noncomputable def sheetMap (d : EvenlyCoveredAt p b) (i : d.I) :
      ContinuousMap (Subtype fun x : B => x ‚ąą d.U)
                    (Subtype fun e : E => p e ‚ąą d.U) :=
  by
    classical
    letI : TopologicalSpace d.I := d.instTopI
    refine ‚ü®(fun u => d.e.symm (u, i)), ?_‚ü©
    have hpair : Continuous fun u : Subtype (fun x : B => x ‚ąą d.U) => (u, i) := by
      have h1 : Continuous fun u : Subtype (fun x : B => x ‚ąą d.U) => u := continuous_id
      have h2 : Continuous fun _u : Subtype (fun x : B => x ‚ąą d.U) => i := continuous_const
      simpa using h1.prodMk h2
    have hcont : Continuous (fun u : Subtype (fun x : B => x ‚ąą d.U) => d.e.symm (u, i)) :=
      d.e.continuous_symm.comp hpair
    simpa using hcont

  /- ő≤-rule at the bundled `ContinuousMap` level:
     `(p ‚ąė inclE ‚ąė sheetMap i) = inclB` on `U`. -/
  @[simp] lemma sheet_comp_eq_inclB (h : CoveringMap p)
      (d : EvenlyCoveredAt p b) (i : d.I) :
      (((‚ü®p, h.continuous‚ü© : ContinuousMap E B)).comp (d.inclE)).comp (d.sheetMap i) = d.inclB := by
    classical
    -- Align the topology instance on `d.I` with the one stored in `d`.
    letI : TopologicalSpace d.I := d.instTopI
    ext u
    -- Evaluate pointwise and use `d.base` with `s = d.e.symm (u,i)`.
    change p ((d.e.symm (u, i)).1) = u.1
    set s := d.e.symm (u, i)
    have hs : d.e s = (u, i) := by
      subst s; simp [sheetMap] using (d.e.left_inv (u, i))
    have hb : ((d.e s).1 : Subtype fun x : B => x ‚ąą d.U).1 = p s.1 := d.base s
    -- From `hs`, the first projection equals `u` as a subtype.
    have hfst : ((d.e s).1) = u := congrArg Prod.fst hs
    have hfst_val : ((d.e s).1).1 = u.1 := by
      simpa using congrArg Subtype.val hfst
    -- Combine: `u.1 = p s.1`.
    have : u.1 = p s.1 := by
      simpa [hfst_val] using hb
    -- Rewrite back the definition of `s`.
    simpa [s] using this.symm

  /- ### Local lifting for maps landing in `U` -/

  -- Phase 3: local lifting for maps, scoped under a single local instance.
  section LocalLift
  variable {Z : Type*} [TopologicalSpace Z]

  /-- Package a map `ő≥ : Z ‚Üí B` with image in `U` as a map into the subtype. -/
  noncomputable def toSubtype (d : EvenlyCoveredAt p b)
      (ő≥ : ContinuousMap Z B) (hő≥ : ‚ąÄ z, ő≥ z ‚ąą d.U) :
      ContinuousMap Z (Subtype fun x : B => x ‚ąą d.U) :=
    ‚ü®(fun z => ‚ü®ő≥ z, hő≥ z‚ü©),
      by
        have hcont : Continuous fun z => ő≥ z := ő≥.continuous
        exact hcont.subtype_mk hő≥‚ü©

  /-- Choose the sheet index determined by a point `e` in the fiber over `U`. -/
  noncomputable def sheetIndexAt (d : EvenlyCoveredAt p b)
      (e : E) (hUE : p e ‚ąą d.U) : d.I :=
  by
    classical
    exact ((d.e ‚ü®e, hUE‚ü©).2)

  /-- The `sheetMap` at index `sheetIndexAt e` passes through the base point `e`. -/
  lemma sheetMap_through (d : EvenlyCoveredAt p b)
      (e : E) (hUE : p e ‚ąą d.U) :
      d.sheetMap (d.sheetIndexAt e hUE) ‚ü®p e, hUE‚ü© = ‚ü®e, hUE‚ü© := by
    classical
    -- Align the topology instance on `d.I` with the one stored in `d`.
    letI : TopologicalSpace d.I := d.instTopI
    -- Apply `d.e` to both sides and use injectivity.
    apply d.e.injective
    -- Left-hand side under `d.e`.
    have lhs : d.e (d.sheetMap (d.sheetIndexAt e hUE) ‚ü®p e, hUE‚ü©)
        = (‚ü®p e, hUE‚ü©, d.sheetIndexAt e hUE) := by
      simp [sheetMap] using d.e.left_inv (‚ü®p e, hUE‚ü©, d.sheetIndexAt e hUE)
    -- Right-hand side under `d.e` equals `(‚ü®p e, hUE‚ü©, d.sheetIndexAt e hUE)`.
    have hfst : (d.e ‚ü®e, hUE‚ü©).1 = ‚ü®p e, hUE‚ü© := by
      apply Subtype.ext
      -- `d.base` gives `((d.e ‚ü®e, hUE‚ü©).1).1 = p e`, matching the expected direction
      simpa using (d.base ‚ü®e, hUE‚ü©)
    have hrs : d.e ‚ü®e, hUE‚ü© = (‚ü®p e, hUE‚ü©, d.sheetIndexAt e hUE) := by
      apply Prod.ext
      ¬∑ exact hfst
      ¬∑ rfl
    -- Conclude by rewriting the RHS with `hrs`.
    simpa [hrs] using lhs

  /-- Local lift of `ő≥` along the `i`-th sheet. -/
  noncomputable def liftAlong (d : EvenlyCoveredAt p b) (_h : CoveringMap p)
      (i : d.I) (ő≥ : ContinuousMap Z B) (hő≥ : ‚ąÄ z, ő≥ z ‚ąą d.U) :
      ContinuousMap Z E :=
    ((d.inclE).comp (d.sheetMap i)).comp (d.toSubtype ő≥ hő≥)

  /-- ő≤-rule for the local lift: composing with `p` recovers `ő≥`. -/
  @[simp] lemma liftAlong_beta (d : EvenlyCoveredAt p b) (h : CoveringMap p)
      (i : d.I) (ő≥ : ContinuousMap Z B) (hő≥ : ‚ąÄ z, ő≥ z ‚ąą d.U) :
      ((‚ü®p, h.continuous‚ü© : ContinuousMap E B)).comp (d.liftAlong h i ő≥ hő≥) = ő≥ := by
    classical
    -- Reassociate and use the bundled ő≤-rule for sheets, then evaluate.
    change ((((‚ü®p, h.continuous‚ü© : ContinuousMap E B)).comp d.inclE).comp (d.sheetMap i)).comp
      (d.toSubtype ő≥ hő≥) = ő≥
    have hő≤ := EvenlyCoveredAt.sheet_comp_eq_inclB (p:=p) (h:=h) (d:=d) (i:=i)
    -- hő≤ : ((‚ü®p,_‚ü©).comp d.inclE).comp (d.sheetMap i) = d.inclB
    ext z
    simp [toSubtype, inclB, ContinuousMap.comp_apply, hő≤]

  end LocalLift


  end EvenlyCoveredAt

  /-
  ### Local path lifting (image contained in one evenly-covered chart)

  For a path `ő≥ : Path b‚āÄ b‚āĀ` whose image is contained in an evenly-covered
  neighborhood `U` around `b‚āÄ`, we can choose a sheet indexed by the starting
  fiber point and lift `ő≥` along that sheet to obtain a path starting at the
  chosen fiber point. The ő≤-rule and uniqueness are immediate from the bundled
  ő≤-rule for `liftAlong` and the injectivity of the product chart.
  -/

  /-
  NOTE (temporary): Path lifting and ő≤-lemmas are deferred until Phase 3‚Äď6.
  The entire `CoveringMap` path-lifting block is commented out.
  -/
  namespace CoveringMap

  open EvenlyCoveredAt

  variable {p : E ‚Üí B}

  /-- Local path lift in an evenly-covered neighborhood containing the whole path image. -/
  noncomputable def liftPathLocal
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (d : EvenlyCoveredAt p b‚āÄ)
      (ő≥ : Path b‚āÄ b‚āĀ)
      (e‚āÄ : E) (h‚āÄ : p e‚āÄ = b‚āÄ)
      (hő≥U : ‚ąÄ t : unitInterval, ő≥ t ‚ąą d.U) :
      Path e‚āÄ ((d.liftAlong h (d.sheetIndexAt e‚āÄ (by simpa [h‚āÄ] using d.memU))
        ő≥.toContinuousMap hő≥U) I1) :=
  by
    classical
    -- Prepare endpoint inclusions and the chosen sheet index
    have hUE‚āÄ : p e‚āÄ ‚ąą d.U := by simpa [h‚āÄ] using d.memU
    set i : d.I := d.sheetIndexAt e‚āÄ hUE‚āÄ with hi
    -- The lifted continuous map on `I := unitInterval`.
    let ő≥E : ContinuousMap (‚ÜĎunitInterval) E := d.liftAlong h i ő≥.toContinuousMap hő≥U
    -- Named endpoints of the unit interval (as a subtype)
    let t0 : ‚ÜĎunitInterval := I0
    let t1 : ‚ÜĎunitInterval := I1
    -- Endpoint at 0 is the chosen fiber point `e‚āÄ`.
    have hő≥E0 : ő≥E t0 = e‚āÄ := by
      -- compute the start value explicitly
      have hU0 : ő≥ t0 ‚ąą d.U := hő≥U t0
      -- Compare with the distinguished sheet-map through e‚āÄ at the base point.
      have Hsheet : (d.sheetMap i ‚ü®p e‚āÄ, hUE‚āÄ‚ü©).1 = e‚āÄ := by
        have := EvenlyCoveredAt.sheetMap_through (p:=p) (b:=b‚āÄ) d e‚āÄ hUE‚āÄ
        simpa [i] using congrArg Subtype.val this
      -- Change the base from `p e‚āÄ` to `b‚āÄ` using `h‚āÄ`.
      have Hbase_b0 : (d.sheetMap i ‚ü®b‚āÄ, by simpa [h‚āÄ] using d.memU‚ü©).1 = e‚āÄ := by
        -- rewrite the input subtype using `p e‚āÄ = b‚āÄ`
        have Heq : (‚ü®b‚āÄ, by simpa [h‚āÄ] using d.memU‚ü© : Subtype fun x : B => x ‚ąą d.U)
          = ‚ü®p e‚āÄ, hUE‚āÄ‚ü© := by
          apply Subtype.ext
          simpa [h‚āÄ]
        -- transport along equality on the input
        simp [EvenlyCoveredAt.sheetMap, Heq] using Hsheet
      -- Now change from `b‚āÄ` to the true start `ő≥ t0` using `ő≥.source`.
      have hő≥0 : ő≥ t0 = b‚āÄ := by simpa [t0] using (path_source_I0 (ő≥ := ő≥))
      have Hstart : (d.sheetMap i ‚ü®ő≥ t0, hU0‚ü©).1 = e‚āÄ := by
        have Heq : (‚ü®ő≥ t0, hU0‚ü© : Subtype fun x : B => x ‚ąą d.U)
          = ‚ü®b‚āÄ, by simpa [h‚āÄ] using d.memU‚ü© := by
          apply Subtype.ext; simpa [hő≥0]
        simp [EvenlyCoveredAt.sheetMap, Heq] using Hbase_b0
      -- unfold the definition of ő≥E at 0
      simp [ő≥E, EvenlyCoveredAt.liftAlong, EvenlyCoveredAt.toSubtype, EvenlyCoveredAt.inclE, EvenlyCoveredAt.sheetMap]
        using Hstart
    -- Package as a path by taking the underlying bundled map and endpoints.
    refine
      { toContinuousMap := ő≥E
      , source' := hő≥E0
      , target' := rfl }

  /-- ő≤-rule for the local path lift (bundled path-level version). -/
  lemma liftPathLocal_map_apply
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (d : EvenlyCoveredAt p b‚āÄ)
      (ő≥ : Path b‚āÄ b‚āĀ)
      (e‚āÄ : E) (h‚āÄ : p e‚āÄ = b‚āÄ)
      (hő≥U : ‚ąÄ t : unitInterval, ő≥ t ‚ąą d.U) (t : ‚ÜĎunitInterval) :
      ((liftPathLocal (p:=p) h d ő≥ e‚āÄ h‚āÄ hő≥U).map (f := p) h.continuous) t = ő≥ t := by
    classical
    -- set up the sheet index used in `liftPathLocal`
    have hUE‚āÄ : p e‚āÄ ‚ąą d.U := by simpa [h‚āÄ] using d.memU
    set i : d.I := d.sheetIndexAt e‚āÄ hUE‚āÄ with hi
    -- bundled ő≤ for `liftAlong`
    have hő≤ := EvenlyCoveredAt.liftAlong_beta (p:=p) (b:=b‚āÄ) (d:=d) (h:=h)
      (i:=i) (ő≥:=ő≥.toContinuousMap) (hő≥:=hő≥U)
    -- evaluate both sides at `t`
    -- simplify both sides to pointwise equality
    simp [liftPathLocal, path_map_apply, EvenlyCoveredAt.liftAlong, EvenlyCoveredAt.toSubtype, ContinuousMap.comp_apply]
      using congrArg (fun F => F t) hő≤

  -- Uniqueness for the local lift with fixed start can be proved by transporting
  -- both lifts along `d.e` and using injectivity; we postpone this global proof
  -- until the gluing step is in place.

  end CoveringMap


  -- We avoid adding a general `@[simp]` lemma for `Path.map_trans` here to keep
  -- dependencies light; in the few places we need it, we use `ext; rfl`.

  /-
  ### Subpaths and reparametrization of the unit interval

  We provide a linear reparametrization `segMap a b : I ‚Üí I` that maps `0 ‚Ü¶ a`,
  `1 ‚Ü¶ b`, and use it to define the subpath `ő≥.subpath a b`.
  -/

  -- Local path utilities are namespaced under `Bourbaki.TopologyB.Path`.
  -- Phase 1: enabled.
  namespace Path

  open scoped Topology

  variable {b‚āÄ b‚āĀ : B}

  /-- Linear reparametrization of the unit interval sending `0 ‚Ü¶ a` and `1 ‚Ü¶ b`. -/
  noncomputable def segMap (a b : unitInterval) : ContinuousMap unitInterval unitInterval :=
  by
    -- Define the underlying real-valued function.
    refine ‚ü®(fun t => ‚ü®(1 - (t : ‚ĄĚ)) * (a : ‚ĄĚ) + (t : ‚ĄĚ) * (b : ‚ĄĚ), ?mem‚ü©), ?cont‚ü©
    ¬∑ -- Membership in [0,1].
      -- Nonnegativity
      have ha0 : 0 ‚Č§ (a : ‚ĄĚ) := a.2.1
      have hb0 : 0 ‚Č§ (b : ‚ĄĚ) := b.2.1
      have ht0 : 0 ‚Č§ (t : ‚ĄĚ) := t.2.1
      have ht1 : (t : ‚ĄĚ) ‚Č§ 1 := t.2.2
      have h1t0 : 0 ‚Č§ 1 - (t : ‚ĄĚ) := sub_nonneg.mpr ht1
      have h1t1 : (1 - (t : ‚ĄĚ)) + (t : ‚ĄĚ) = 1 := by ring
      have h0 : 0 ‚Č§ (1 - (t : ‚ĄĚ)) * (a : ‚ĄĚ) + (t : ‚ĄĚ) * (b : ‚ĄĚ) := by
        have h‚āĀ : 0 ‚Č§ (1 - (t : ‚ĄĚ)) * (a : ‚ĄĚ) := mul_nonneg h1t0 ha0
        have h‚āā : 0 ‚Č§ (t : ‚ĄĚ) * (b : ‚ĄĚ) := mul_nonneg ht0 hb0
        exact add_nonneg h‚āĀ h‚āā
      have ha1 : (a : ‚ĄĚ) ‚Č§ 1 := a.2.2
      have hb1 : (b : ‚ĄĚ) ‚Č§ 1 := b.2.2
      have hle : (1 - (t : ‚ĄĚ)) * (a : ‚ĄĚ) + (t : ‚ĄĚ) * (b : ‚ĄĚ)
                  ‚Č§ (1 - (t : ‚ĄĚ)) * 1 + (t : ‚ĄĚ) * 1 := by
        refine add_le_add ?_ ?_
        ¬∑ exact mul_le_mul_of_nonneg_left ha1 h1t0
        ¬∑ exact mul_le_mul_of_nonneg_left hb1 ht0
      have hone : (1 - (t : ‚ĄĚ)) * 1 + (t : ‚ĄĚ) * 1 = 1 := by
        simpa [h1t1] using by ring
      exact ‚ü®h0, by simpa [hone] using hle‚ü©
    ¬∑ -- Continuity.
      have ht : Continuous fun t : unitInterval => (t : ‚ĄĚ) := continuous_subtype_val
      have h‚āĀ : Continuous fun t : unitInterval => (1 - (t : ‚ĄĚ)) := continuous_const.sub ht
      have h‚āā : Continuous fun _ : unitInterval => (a : ‚ĄĚ) := continuous_const
      have h‚āÉ : Continuous fun _ : unitInterval => (b : ‚ĄĚ) := continuous_const
      have hleft : Continuous fun t : unitInterval => (1 - (t : ‚ĄĚ)) * (a : ‚ĄĚ) := h‚āĀ.mul h‚āā
      have hright : Continuous fun t : unitInterval => (t : ‚ĄĚ) * (b : ‚ĄĚ) := ht.mul h‚āÉ
      have hcont : Continuous fun t : unitInterval =>
          (1 - (t : ‚ĄĚ)) * (a : ‚ĄĚ) + (t : ‚ĄĚ) * (b : ‚ĄĚ) := hleft.add hright
      -- upgrade to continuity into the subtype via `subtype_mk`
      exact hcont.subtype_mk (by
        intro t
        -- Reproduce the membership proof pointwise
        have ha0 : 0 ‚Č§ (a : ‚ĄĚ) := a.2.1
        have hb0 : 0 ‚Č§ (b : ‚ĄĚ) := b.2.1
        have ht0 : 0 ‚Č§ (t : ‚ĄĚ) := t.2.1
        have ht1 : (t : ‚ĄĚ) ‚Č§ 1 := t.2.2
        have h1t0 : 0 ‚Č§ 1 - (t : ‚ĄĚ) := sub_nonneg.mpr ht1
        have h1t1 : (1 - (t : ‚ĄĚ)) + (t : ‚ĄĚ) = 1 := by ring
        have h0 : 0 ‚Č§ (1 - (t : ‚ĄĚ)) * (a : ‚ĄĚ) + (t : ‚ĄĚ) * (b : ‚ĄĚ) := by
          have h‚āĀ : 0 ‚Č§ (1 - (t : ‚ĄĚ)) * (a : ‚ĄĚ) := mul_nonneg h1t0 ha0
          have h‚āā : 0 ‚Č§ (t : ‚ĄĚ) * (b : ‚ĄĚ) := mul_nonneg ht0 hb0
          exact add_nonneg h‚āĀ h‚āā
        have ha1 : (a : ‚ĄĚ) ‚Č§ 1 := a.2.2
        have hb1 : (b : ‚ĄĚ) ‚Č§ 1 := b.2.2
        have hle : (1 - (t : ‚ĄĚ)) * (a : ‚ĄĚ) + (t : ‚ĄĚ) * (b : ‚ĄĚ)
                    ‚Č§ (1 - (t : ‚ĄĚ)) * 1 + (t : ‚ĄĚ) * 1 := by
          refine add_le_add ?_ ?_
          ¬∑ exact mul_le_mul_of_nonneg_left ha1 h1t0
          ¬∑ exact mul_le_mul_of_nonneg_left hb1 ht0
        have hone : (1 - (t : ‚ĄĚ)) * 1 + (t : ‚ĄĚ) * 1 = 1 := by
          simpa [h1t1] using by ring
        exact ‚ü®h0, by simpa [hone] using hle‚ü©)

  @[simp] lemma segMap_I0 (a b : unitInterval) :
      segMap a b I0 = a := by
    ext; simp [segMap, I0, one_mul]

  @[simp] lemma segMap_I1 (a b : unitInterval) :
      segMap a b I1 = b := by
    ext; simp [segMap, I1]

  -- Friendly names requested in the guide
  @[simp] lemma segMap_zero (a b : unitInterval) :
      segMap a b (0 : unitInterval) = a := by
    simpa [I0] using (segMap_I0 a b)

  @[simp] lemma segMap_one (a b : unitInterval) :
      segMap a b (1 : unitInterval) = b := by
    simpa [I1] using (segMap_I1 a b)

  /-- Subpath of `ő≥` between times `a` and `b` in the unit interval. -/
  noncomputable def subpath (ő≥ : Path b‚āÄ b‚āĀ)
      (a b : unitInterval) : Path (ő≥ a) (ő≥ b) :=
  { toContinuousMap := ő≥.toContinuousMap.comp (segMap a b)
  , source' := by
      change (ő≥.toContinuousMap (segMap a b I0)) = ő≥ a
      simpa [ContinuousMap.comp_apply] using congrArg (fun x => ő≥.toContinuousMap x)
        (segMap_I0 a b)
  , target' := by
      change (ő≥.toContinuousMap (segMap a b I1)) = ő≥ b
      simpa [ContinuousMap.comp_apply] using congrArg (fun x => ő≥.toContinuousMap x)
        (segMap_I1 a b) }

  end Path

  /-
  NOTE (temporary): Localized subinterval lifting and 2-segment gluing are
  deferred; comment out to keep build green.
  -/
  namespace CoveringMap

  open Path EvenlyCoveredAt

  variable {p : E ‚Üí B}

  /-- Local lift on a subinterval `[a,b]` whose image lands in an evenly-covered chart. -/
  noncomputable def liftPathLocalOn
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ)
      (a b : unitInterval)
      (d : EvenlyCoveredAt p (ő≥ a))
      (e‚āź : E) (h‚āź : p e‚āź = ő≥ a)
      (hő≥U : ‚ąÄ t : unitInterval, ő≥ (Bourbaki.TopologyB.Path.segMap a b t) ‚ąą d.U) :
      Path e‚āź ((d.liftAlong h (d.sheetIndexAt e‚āź (by
        have : ő≥ a ‚ąą d.U := by
          simpa using hő≥U I0
        simpa [h‚āź] using this))
        (ő≥.toContinuousMap.comp (Bourbaki.TopologyB.Path.segMap a b))
        (by intro t; simpa using hő≥U t)) I1) :=
  by
    classical
    -- Prepare the sheet index at the starting endpoint a
    have hUa : ő≥ a ‚ąą d.U := by simpa using hő≥U I0
    set i : d.I := d.sheetIndexAt e‚āź (by simpa [h‚āź] using hUa) with hi
    -- The lifted continuous map on the subinterval
    let ő≥E : ContinuousMap (‚ÜĎunitInterval) E :=
      d.liftAlong h i (ő≥.toContinuousMap.comp (Bourbaki.TopologyB.Path.segMap a b))
        (by intro t; simpa using hő≥U t)
    -- Endpoints in the unit interval subtype
    let t0 : ‚ÜĎunitInterval := I0
    let t1 : ‚ÜĎunitInterval := I1
    -- Startpoint: use the sheetMap_through at ő≥ a and rewrite by h‚āź
    have hő≥E0 : ő≥E t0 = e‚āź := by
      have : (d.sheetMap i ‚ü®ő≥ a, hUa‚ü©).1 = e‚āź := by
        -- through property at the starting base point
        have := EvenlyCoveredAt.sheetMap_through (p:=p) d e‚āź (by simpa [h‚āź] using hUa)
        simpa [i, h‚āź] using congrArg Subtype.val this
      -- evaluate ő≥E at t0 and simplify
      simpa [ő≥E, EvenlyCoveredAt.liftAlong, EvenlyCoveredAt.toSubtype,
              EvenlyCoveredAt.inclE, EvenlyCoveredAt.sheetMap,
              Bourbaki.TopologyB.Path.segMap, t0, I0]
        using this
    -- Package as a path
    refine
      { toContinuousMap := ő≥E
      , source' := hő≥E0
      , target' := rfl }

  /-- ő≤-rule (apply-level) for the localized lift on `[a,b]`. -/
  lemma liftPathLocalOn_map_apply
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ)
      (a b : unitInterval)
      (d : EvenlyCoveredAt p (ő≥ a))
      (e‚āź : E) (h‚āź : p e‚āź = ő≥ a)
      (hő≥U : ‚ąÄ t : unitInterval, ő≥ (Bourbaki.TopologyB.Path.segMap a b t) ‚ąą d.U)
      (t : unitInterval) :
      ((liftPathLocalOn (p:=p) h ő≥ a b d e‚āź h‚āź hő≥U).map (f := p) h.continuous) t
        = (Bourbaki.TopologyB.Path.subpath ő≥ a b) t := by
    classical
    -- bundled ő≤ for the lifted map on the subinterval (pointwise)
    have hő≤ := EvenlyCoveredAt.liftAlong_beta (p:=p) (b:=ő≥ a) (d:=d) (h:=h)
      (i:=d.sheetIndexAt e‚āź (by
        have : ő≥ a ‚ąą d.U := by simpa using hő≥U I0
        simpa [h‚āź] using this))
      (ő≥:=ő≥.toContinuousMap.comp (Bourbaki.TopologyB.Path.segMap a b))
      (hő≥:=by intro t'; simpa using hő≥U t')
    have := congrArg (fun F => F t) hő≤
    simpa [liftPathLocalOn, path_map_apply, EvenlyCoveredAt.liftAlong,
            EvenlyCoveredAt.toSubtype, ContinuousMap.comp_apply]
      using this

  /-- Glue two local lifts over adjacent subintervals `[a,c]` and `[c,b]`. -/
  noncomputable def liftPathTwo
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ)
      (a c b : unitInterval)
      (h_ac : (a : ‚ĄĚ) ‚Č§ c ‚ąß c ‚Č§ b)
      (d‚āĀ : EvenlyCoveredAt p (ő≥ a)) (d‚āā : EvenlyCoveredAt p (ő≥ c))
      (e‚āź : E) (h‚āź : p e‚āź = ő≥ a)
      (hő≥U‚āĀ : ‚ąÄ t : unitInterval, ő≥ (Bourbaki.TopologyB.Path.segMap a c t) ‚ąą d‚āĀ.U)
      (hő≥U‚āā : ‚ąÄ t : unitInterval, ő≥ (Bourbaki.TopologyB.Path.segMap c b t) ‚ąą d‚āā.U) :
      Path e‚āź ((liftPathLocalOn (p:=p) h ő≥ c b d‚āā
        ((liftPathLocalOn (p:=p) h ő≥ a c d‚āĀ e‚āź h‚āź hő≥U‚āĀ) I1)
        (by
          -- equality `p (őď‚āĀ 1) = ő≥ c` via apply-level local ő≤ at endpoint
          have hő≤ := liftPathLocal_map_apply (p:=p) h d‚āĀ (Bourbaki.TopologyB.Path.subpath ő≥ a c)
            e‚āź h‚āź (by intro t; simpa [Bourbaki.TopologyB.Path.subpath, ContinuousMap.comp_apply] using hő≥U‚āĀ t) I1
          simpa [Bourbaki.TopologyB.Path.subpath, path_map_apply] using hő≤)
        hő≥U‚āā) I1) :=
  by
    classical
    -- Define the two local lifts and compose them via `Path.trans`.
    let őď‚āĀ := liftPathLocalOn (p:=p) h ő≥ a c d‚āĀ e‚āź h‚āź hő≥U‚āĀ
    let e_c := őď‚āĀ I1
    have hcstart : p e_c = ő≥ c := by
      -- pointwise ő≤ at endpoint using the apply-level lemma
      have := liftPathLocal_map_apply (p:=p) h d‚āĀ (Bourbaki.TopologyB.Path.subpath ő≥ a c)
        e‚āź h‚āź (by intro t; simpa [Bourbaki.TopologyB.Path.subpath, ContinuousMap.comp_apply] using hő≥U‚āĀ t) I1
      simpa [őď‚āĀ, Bourbaki.TopologyB.Path.subpath, path_map_apply] using this
    let őď‚āā := liftPathLocalOn (p:=p) h ő≥ c b d‚āā e_c hcstart hő≥U‚āā
    -- Compose the two lifted paths.
    exact őď‚āĀ.trans őď‚āā

  end CoveringMap


  /-
  ### Finite path covers and global lifting

  We package a finite partition of the unit interval together with evenly-covered
  charts per subinterval, and glue the corresponding local lifts into a global
  lift over `[0,1]`.
  -/

  /-
  NOTE (temporary): Finite path cover and global fold are deferred; comment out
  to complete early phases first.
  -/
  namespace CoveringMap

  open Path EvenlyCoveredAt

  variable {p : E ‚Üí B}

  /-- A finite cover of a path by evenly-covered neighborhoods, indexed by a finite
  increasing sequence of parameters `pts : Fin (n+1) ‚Üí I`. On each subinterval
  `[pts i, pts (i.succ)]`, the image of the path is contained in the neighborhood
  `charts i`. We keep only the data needed to perform gluing; monotonicity is
  not used explicitly here as we only rely on endpoints of subpaths. -/
  structure PathCover {b‚āÄ b‚āĀ : B} (p : E ‚Üí B) (ő≥ : Path b‚āÄ b‚āĀ) where
    n : Nat
    pts : Fin (n+1) ‚Üí unitInterval
    start : pts ‚ü®0, by
      have : (0 : Nat) < n + 1 := Nat.succ_pos _
      exact this‚ü© = I0
    stop : pts ‚ü®n, by
      have : n < n + 1 := Nat.lt_succ_self _
      exact this‚ü© = I1
    charts : ‚ąÄ i : Fin n, EvenlyCoveredAt p (ő≥ (pts i.castSucc))
    inU : ‚ąÄ i : Fin n, ‚ąÄ t : unitInterval,
      ő≥ (Bourbaki.TopologyB.Path.segMap (pts i.castSucc) (pts i.succ) t) ‚ąą (charts i).U

  /- Left-fold concatenation core up to index `k` (apply-level fold nucleus).
     Returns a path from `ő≥ I0` to `ő≥ (cov.pts k)` built by concatenating
     subpaths `[pts i.castSucc, pts i.succ]` for `i = 0..k-1`. -/
  noncomputable def coverConcatCore {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ) (cov : PathCover (p:=p) ő≥) :
      (k : Fin (cov.n + 1)) ‚Üí Path b‚āÄ (ő≥ (cov.pts k))
  | ‚ü®0, _hk0‚ü© =>
    -- Base: trivial path at b‚āÄ; target is ő≥ (pts 0) = ő≥ I0 = b‚āÄ
    { toContinuousMap := (Path.refl b‚āÄ).toContinuousMap
    , source' := by simpa using (Path.refl b‚āÄ).source
    , target' := by
        -- Target must be `ő≥ (cov.pts ‚ü®0, _hk0‚ü©)`; align `cov.start` index first.
        have hidx : (0 : Fin (cov.n+1)) = ‚ü®0, _hk0‚ü© := by rfl
        have hstart0 : cov.pts 0 = I0 := by simpa using cov.start
        have h0' : ő≥ (cov.pts ‚ü®0, _hk0‚ü©) = b‚āÄ := by
          simpa [hstart0] using (path_source_I0 (ő≥ := ő≥))
        have h0 : b‚āÄ = ő≥ (cov.pts ‚ü®0, _hk0‚ü©) := h0'.symm
        simpa [h0] using (Path.refl b‚āÄ).target }
  | ‚ü®Nat.succ k, hk‚ü© =>
    -- Induction: concatenate previous segment with subpath on [pts i.castSucc, pts i.succ]
    let hklt : k < cov.n := Nat.succ_lt_succ_iff.mp hk
    let i : Fin cov.n := ‚ü®k, hklt‚ü©
    have hk' : k ‚Č§ cov.n := le_of_lt hklt
    -- Previous fold up to k (as a Fin in n+1)
    have prev : Path b‚āÄ (ő≥ (cov.pts ‚ü®k, Nat.lt_succ_of_le hk'‚ü©)) :=
      coverConcatCore ő≥ cov ‚ü®k, Nat.lt_succ_of_le hk'‚ü©
    -- Concatenate with the subpath on the next interval
    prev.trans (Bourbaki.TopologyB.Path.subpath ő≥ (cov.pts i.castSucc) (cov.pts i.succ))


  /-- The concatenation over the whole cover, exposed via the left-fold core. -/
  noncomputable def coverConcat {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ) (cov : PathCover (p:=p) ő≥) : Path b‚āÄ b‚āĀ :=
  by
    classical
    -- Take the fold up to `n` and retag the target using `ő≥ I1 = b‚āĀ` and `cov.stop`.
    let őī := coverConcatCore (p:=p) ő≥ cov ‚ü®cov.n, by simpa using Nat.lt_succ_self _‚ü©
    refine
      { toContinuousMap := őī.toContinuousMap
      , source' := by simpa using őī.source
      , target' := ?_ }
    -- endpoint at `1` equals `b‚āĀ`; align the index in `cov.stop`
    have hidx : (‚ü®cov.n, by simpa using Nat.lt_succ_self _‚ü© : Fin (cov.n+1))
              = ‚ü®cov.n, by
                  have : cov.n < cov.n + 1 := Nat.lt_succ_self _
                  exact this‚ü© := by
      ext; rfl
    have hstop : cov.pts ‚ü®cov.n, by simpa using Nat.lt_succ_self _‚ü© = I1 := by
      simpa [hidx] using (cov.stop)
    have hb1 : ő≥ (cov.pts ‚ü®cov.n, by simpa using Nat.lt_succ_self _‚ü©) = b‚āĀ := by
      simpa [hstop] using (path_target_I1 (ő≥ := ő≥))
    simpa [hb1] using őī.target

  -- We deliberately avoid asserting that `coverConcat` pointwise equals a
  -- single `subpath` of `ő≥`: the concatenation via `Path.trans` composes
  -- segments with a different (piecewise) reparametrization than a single
  -- linear `segMap`. This keeps the fold nucleus compatible with later ő≤-lemmas.

  /-
  -- Concatenation of the subpaths determined by a `PathCover`. This is a
  canonical reparametrization of `ő≥` by the partition points `cov.pts`. -/
  /- NOTE: Phase 6 (coverConcat/liftPathOnCover) deferred; commenting out to keep build green.
  noncomputable def coverConcat {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ) (cov : PathCover (p:=p) ő≥) : Path b‚āÄ b‚āĀ :=
  by
    classical
    -- Build the concatenation up to step `k` with target `ő≥ (pts k)`.
    let build : ‚ąÄ k, (hk : k ‚Č§ cov.n) ‚Üí Path b‚āÄ (ő≥ (cov.pts ‚ü®k, Nat.lt_succ_of_le hk‚ü©))
    | 0, hk =>
      -- At k = 0, `pts 0 = 0`, so the trivial path works.
      have h0 : ő≥ (cov.pts ‚ü®0, Nat.succ_pos _‚ü©) = b‚āÄ := by
        simpa [cov.start] using (path_source_I0 (ő≥ := ő≥))
      -- Adjust the target via rewriting to match the required type.
      { toContinuousMap := (Path.refl b‚āÄ).toContinuousMap
      , source' := by simpa using (Path.refl b‚āÄ).source
      , target' := by simpa [h0] using (Path.refl b‚āÄ).target }
    | (Nat.succ k), hk =>
      -- Previous stage
      have hk' : k ‚Č§ cov.n := le_trans (Nat.le_succ k) hk
      have hklt : k < cov.n := lt_of_lt_of_le (Nat.lt_succ_self k) hk
      let i : Fin cov.n := ‚ü®k, hklt‚ü©
      -- Glue previous with the subpath on `[pts i, pts i.succ]`.
      (build k hk').trans (Bourbaki.TopologyB.Path.subpath ő≥ (cov.pts i.castSucc) (cov.pts i.succ))
    -- final path ends at `ő≥ 1 = b‚āĀ`
    { toContinuousMap := (build cov.n le_rfl).toContinuousMap
    , source' := by simpa using (build cov.n le_rfl).source
    , target' := by
        have : ő≥ (cov.pts ‚ü®cov.n, Nat.lt_succ_self _‚ü©) = b‚āĀ := by
          have : ő≥ I1 = b‚āĀ := by simpa using (path_target_I1 (ő≥ := ő≥))
          simpa [cov.stop] using this
        simpa [this] using (build cov.n le_rfl).target }

  /-- Glue local lifts along the subintervals of a `PathCover` to obtain a global lift
  over the whole interval. Returns the endpoint in the fiber and the lifted path. -/
  noncomputable def liftPathOnCover
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ)
      (cov : PathCover (p:=p) ő≥)
      (e‚āÄ : E) (h‚āÄ : p e‚āÄ = b‚āÄ) :
      ő£ e : E, Path e‚āÄ e :=
  by
    classical
    -- Strong recursion storing the endpoint relation `p e_k = ő≥ (pts k)`.
  private noncomputable def liftPathOnCover.build
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ) (cov : PathCover (p:=p) ő≥)
      (e‚āÄ : E) (h‚āÄ : p e‚āÄ = b‚āÄ) :
      ‚ąÄ k (hk : k ‚Č§ cov.n), ő£ e : E, Path e‚āÄ e √ó
        (p e = ő≥ (cov.pts ‚ü®k, Nat.lt_succ_of_le hk‚ü©)) :=
  by
    classical
    intro k
    induction' k with k ih generalizing e‚āÄ
    ¬∑ intro hk
      exact
        ‚ü®e‚āÄ, (Path.refl e‚āÄ, by
          have : ő≥ (cov.pts ‚ü®0, Nat.succ_pos _‚ü©) = b‚āÄ := by
            simpa [cov.start] using (path_source_I0 (ő≥ := ő≥))
          simpa [this] using h‚āÄ)‚ü©
    ¬∑ intro hkSucc
      have hk' : k ‚Č§ cov.n := le_trans (Nat.le_succ k) hkSucc
      rcases ih hk' with ‚ü®e_k, őď_k, hkrel‚ü©
      have hklt : k < cov.n := lt_of_lt_of_le (Nat.lt_succ_self k) hkSucc
      let i : Fin cov.n := ‚ü®k, hklt‚ü©
      have hidx : (‚ü®k, by exact Nat.lt_succ_of_le hk'‚ü© : Fin (cov.n + 1)) = i.castSucc := by
        ext; rfl
      have hstart : p e_k = ő≥ (cov.pts i.castSucc) := by simpa [hidx] using hkrel
      let őďseg :=
        liftPathLocalOn (p:=p) h ő≥ (cov.pts i.castSucc) (cov.pts i.succ) (cov.charts i)
          e_k hstart (cov.inU i)
      have hend : p (őďseg I1) = ő≥ (cov.pts i.succ) := by
        have hő≤ := liftPathLocalOn_map_apply (p:=p) h ő≥ (cov.pts i.castSucc) (cov.pts i.succ)
          (cov.charts i) e_k hstart (cov.inU i) I1
        simpa [őďseg, path_map_apply, Bourbaki.TopologyB.Path.subpath,
          ContinuousMap.comp_apply] using hő≤
      exact ‚ü®őďseg I1, (őď_k.trans őďseg, by simpa using hend)‚ü©

  lemma liftPathOnCover.build_map_apply
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ) (cov : PathCover (p:=p) ő≥) :
      ‚ąÄ {k} (hk : k ‚Č§ cov.n) {e‚āÄ : E} (h‚āÄ : p e‚āÄ = b‚āÄ) (t : unitInterval),
        let data := liftPathOnCover.build (h:=h) ő≥ cov e‚āÄ h‚āÄ k hk
        in ((data.2.1).map (f := p) h.continuous) t =
          (coverConcatCore ő≥ cov ‚ü®k, Nat.lt_succ_of_le hk‚ü©) t :=
  by
    classical
    intro k
    induction' k with k ih generalizing e‚āÄ
    ¬∑ intro hk e‚āÄ h‚āÄ t
      have hidx : (‚ü®0, Nat.lt_succ_of_le hk‚ü© : Fin (cov.n + 1)) = ‚ü®0, Nat.succ_pos _‚ü© := by
        ext; rfl
      have hpts0 : cov.pts ‚ü®0, Nat.lt_succ_of_le hk‚ü© = I0 := by
        simpa [hidx] using cov.start
      have hstart : ő≥ (cov.pts ‚ü®0, Nat.lt_succ_of_le hk‚ü©) = b‚āÄ := by
        simpa [hpts0] using (path_source_I0 (ő≥ := ő≥))
      have hstart0 : cov.pts 0 = I0 := by simpa [hidx] using cov.start
      have hstartő≥ : ő≥ (cov.pts 0) = b‚āÄ := by simpa [hstart0] using (path_source_I0 (ő≥ := ő≥))
      have : ((Path.refl e‚āÄ).map (f := p) h.continuous) t = p e‚āÄ := by simp [path_map_apply]
      simp [liftPathOnCover.build, coverConcatCore, path_map_apply, h‚āÄ, hstart0, hidx, hstartő≥, this]

    ¬∑ intro hkSucc e‚āÄ h‚āÄ t
      have hk' : k ‚Č§ cov.n := Nat.le_of_lt_succ hkSucc
      have hklt : k < cov.n := lt_of_lt_of_le (Nat.lt_succ_self k) hkSucc
      set data := liftPathOnCover.build (h:=h) ő≥ cov e‚āÄ h‚āÄ k hk' with hdata
      rcases data with ‚ü®e_k, őďkData‚ü©
      rcases őďkData with ‚ü®őď_k, hkrel‚ü©
      have hkmap := ih hk' (e‚āÄ := e‚āÄ) (h‚āÄ := h‚āÄ) t
      let i : Fin cov.n := ‚ü®k, hklt‚ü©
      have hidx : (‚ü®k, by exact Nat.lt_succ_of_le hk'‚ü© : Fin (cov.n + 1)) = i.castSucc := by
        ext; rfl
      have hstart : p e_k = ő≥ (cov.pts i.castSucc) := by simpa [hidx] using hkrel
      let őďseg :=
        liftPathLocalOn (p:=p) h ő≥ (cov.pts i.castSucc) (cov.pts i.succ) (cov.charts i)
          e_k hstart (cov.inU i)
      have hőďseg := liftPathLocalOn_map_apply (p:=p) h ő≥ (cov.pts i.castSucc) (cov.pts i.succ)
        (cov.charts i) e_k hstart (cov.inU i) t
      have hgoal :
          ((őď_k.map (f := p) h.continuous).trans (őďseg.map (f := p) h.continuous)) t =
            (coverConcatCore ő≥ cov ‚ü®Nat.succ k, Nat.lt_succ_of_le hkSucc‚ü©) t := by
        simp [coverConcatCore, őďseg, hkmap, hőďseg, path_map_apply]
      have htrans :=
        map_trans_path_apply (őĪ:=őď_k) (ő≤:=őďseg) (f:=p) (hf:=h.continuous) t
      have hőď :
          ((őď_k.trans őďseg).map (f := p) h.continuous) t =
            (coverConcatCore ő≥ cov ‚ü®Nat.succ k, Nat.lt_succ_of_le hkSucc‚ü©) t :=
        htrans.trans hgoal
      have hbuild :
          ((liftPathOnCover.build (h:=h) ő≥ cov e‚āÄ h‚āÄ (Nat.succ k) hkSucc).2.1.map (f := p) h.continuous) t =
            ((őď_k.trans őďseg).map (f := p) h.continuous) t := by
        simp [liftPathOnCover.build, hk', hklt, őďseg]
      simpa [hdata] using hbuild.trans hőď

  /-- Glue local lifts along the subintervals of a PathCover to obtain a global lift
  over the whole interval. Returns the endpoint in the fiber and the lifted path. -/
  noncomputable def liftPathOnCover
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ)
      (cov : PathCover (p:=p) ő≥)
      (e‚āÄ : E) (h‚āÄ : p e‚āÄ = b‚āÄ) :
      ő£ e : E, Path e‚āÄ e :=
  by
    classical
    let data := liftPathOnCover.build (h:=h) ő≥ cov e‚āÄ h‚āÄ cov.n le_rfl
    exact ‚ü®data.1, data.2.1‚ü©

  /-- ő≤-rule for liftPathOnCover: after composing with p, one recovers the
  canonical concatenation of the base path determined by the cover. -/
  lemma liftPathOnCover_map_apply
      (h : CoveringMap p) {b‚āÄ b‚āĀ : B}
      (ő≥ : Path b‚āÄ b‚āĀ)
      (cov : PathCover (p:=p) ő≥)
      (e‚āÄ : E) (h‚āÄ : p e‚āÄ = b‚āÄ) (t : unitInterval) :
      ((liftPathOnCover (p:=p) h ő≥ cov e‚āÄ h‚āÄ).2.map (f := p) h.continuous) t
        = (coverConcat (p:=p) ő≥ cov) t :=
  by
    classical
    set data := liftPathOnCover.build (h:=h) ő≥ cov e‚āÄ h‚āÄ cov.n le_rfl
    have hlift : (liftPathOnCover (p:=p) h ő≥ cov e‚āÄ h‚āÄ).2 = data.2.1 := by
      simp [liftPathOnCover, data]
    have hmap := liftPathOnCover.build_map_apply (h:=h) (ő≥:=ő≥) (cov:=cov)
      (hk := le_rfl) (e‚āÄ := e‚āÄ) (h‚āÄ := h‚āÄ) (t := t)
    have hcover :
        (coverConcat (p:=p) ő≥ cov) t
          = (coverConcatCore ő≥ cov ‚ü®cov.n, by simpa using Nat.lt_succ_self _‚ü©) t := by
      simp [coverConcat]
    simpa [data, hlift, hcover]
      using hmap
  -- ő≤-rule up to the natural reparametrization by the cover can be shown by
  -- folding over segments using `liftPathLocalOn_map` and pushing `Path.map`
  -- through concatenation. Omitted here to keep the skeleton light.

  /-- ő≤-rule for `liftPathOnCover`: composing with `p` recovers `ő≥`.
  Proof outline: fold over segments; each segment satisfies the ő≤-rule by
  `liftPathLocalOn_map`, and `Path.map` respects concatenation. -/
  -- ő≤-rule and uniqueness lemmas for `liftPathOnCover` can be added here once a
  -- compactness-driven extraction lemma for `PathCover` is in place. Their proofs
  -- are mechanical via `ext; simp` from `liftPathLocalOn_map` and `Path.map_trans`.

  -/
  end CoveringMap


  /- NOTE (temporary): Extraction `CoveringMap.evenlyCoveredAt` is deferred
     to keep Phase 0‚Äď2 build stable while we reintroduce local data. -/
