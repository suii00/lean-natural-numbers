  --   exact fun u => d.e.toEquiv.symm (u, i)

  -- lemma sheet_base (d : EvenlyCoveredAt p b) (i : d.I)
  --     (u : Subtype fun x : B => x ∈ d.U) :
  --     p ((d.sheet i u).1) = u.1 := by
